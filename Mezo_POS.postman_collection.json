							"path": ["businesses", "{{businessId}}", "categories", "{{categoryId}}"]
						}
					}
				}
			]
		},
		{
			"name": "04. Products",
			"item": [
				{
					"name": "Create Product (with emoji)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('productId', json.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Cappuccino\",\n  \"price\": 8500,\n  \"currency\": \"COP\",\n  \"description\": \"Espresso con leche espumada\",\n  \"ingredients\": \"café, leche\",\n  \"productionCost\": 3200,\n  \"imageType\": \"EMOJI\",\n  \"image\": \"☕\",\n  \"categoryId\": \"{{categoryId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/products",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "products"]
						}
					}
				},
				{
					"name": "Create Product (without category)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Brownie\",\n  \"price\": 8000,\n  \"currency\": \"COP\",\n  \"description\": \"Brownie de chocolate\",\n  \"imageType\": \"EMOJI\",\n  \"image\": \"🍫\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/products",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "products"]
						}
					}
				},
				{
					"name": "List Products",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/products",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "products"]
						}
					}
				},
				{
					"name": "List Products by Category",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/products?categoryId={{categoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "products"],
							"query": [
								{ "key": "categoryId", "value": "{{categoryId}}" }
							]
						}
					}
				},
				{
					"name": "Get Product",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/products/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "products", "{{productId}}"]
						}
					}
				},
				{
					"name": "Update Product",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Cappuccino Grande\",\n  \"price\": 10500,\n  \"currency\": \"COP\",\n  \"description\": \"Cappuccino tamaño grande\",\n  \"ingredients\": \"café, leche, canela\",\n  \"productionCost\": 4000,\n  \"imageType\": \"EMOJI\",\n  \"image\": \"☕\",\n  \"categoryId\": \"{{categoryId}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/products/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "products", "{{productId}}"]
