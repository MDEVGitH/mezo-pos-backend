						}
					}
				}
			]
		},
		{
			"name": "06. Orders",
			"item": [
				{
					"name": "Create Order (from table)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('orderId', json.id);",
									"    if (json.lines && json.lines.length > 0) {",
									"        pm.collectionVariables.set('orderLineId', json.lines[0].id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"tableId\": \"{{tableId}}\",\n  \"paymentMethod\": \"NEQUI\",\n  \"tip\": 2000,\n  \"lines\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 2 }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/orders",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "orders"]
						}
					}
				},
				{
					"name": "Create Order (direct POS, no table)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('orderId', json.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"tableId\": null,\n  \"paymentMethod\": \"CASH\",\n  \"tip\": 0,\n  \"lines\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 1 }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/orders",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "orders"]
						}
					}
				},
				{
					"name": "List Orders",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/orders",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "orders"]
						}
					}
				},
				{
					"name": "List Orders (filter by status)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/orders?status=OPEN",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "orders"],
							"query": [
								{ "key": "status", "value": "OPEN" }
							]
						}
					}
				},
				{
					"name": "List Orders (filter by table)",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/orders?tableId={{tableId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "orders"],
							"query": [
								{ "key": "tableId", "value": "{{tableId}}" }
							]
						}
					}
				},
				{
					"name": "Get Order",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/orders/{{orderId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "orders", "{{orderId}}"]
						}
					}
				},
				{
					"name": "Add Lines to Order",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"lines\": [\n    { \"productId\": \"{{productId}}\", \"quantity\": 1 }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/orders/{{orderId}}/lines",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "orders", "{{orderId}}", "lines"]
						}
					}
				},
				{
					"name": "Remove Line from Order",
					"request": {
						"method": "DELETE",
