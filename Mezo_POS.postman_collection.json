{
	"info": {
		"name": "Mezo POS API",
		"description": "Colección completa de endpoints para Mezo POS Backend.\n\nFlujo sugerido:\n1. Register → Verify OTP → Login\n2. Create Business\n3. Create Categories → Create Products\n4. Create Tables\n5. Create Order → Add Lines → Update Status\n6. Close Sale\n7. Reports & Analytics",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api/v1"
		},
		{
			"key": "accessToken",
			"value": ""
		},
		{
			"key": "refreshToken",
			"value": ""
		},
		{
			"key": "userId",
			"value": ""
		},
		{
			"key": "businessId",
			"value": ""
		},
		{
			"key": "categoryId",
			"value": ""
		},
		{
			"key": "productId",
			"value": ""
		},
		{
			"key": "tableId",
			"value": ""
		},
		{
			"key": "orderId",
			"value": ""
		},
		{
			"key": "orderLineId",
			"value": ""
		},
		{
			"key": "saleId",
			"value": ""
		},
		{
			"key": "teamUserId",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "01. Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('userId', json.userId);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Test1234!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Verify OTP",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"code\": \"000000\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/verify-otp",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "verify-otp"]
						}
					}
				},
				{
					"name": "Resend OTP",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/resend-otp",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "resend-otp"]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', json.accessToken);",
									"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"    pm.collectionVariables.set('userId', json.user.id);",
									"    if (json.user.businesses && json.user.businesses.length > 0) {",
									"        pm.collectionVariables.set('businessId', json.user.businesses[0].id);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Test1234!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('accessToken', json.accessToken);",
									"    pm.collectionVariables.set('refreshToken', json.refreshToken);",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "refresh"]
						}
					}
				}
			]
		},
		{
			"name": "02. Business",
			"item": [
				{
					"name": "Create Business",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('businessId', json.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Café Mezo\",\n  \"type\": \"CAFE\",\n  \"phone\": \"+573001234567\",\n  \"nit\": \"900123456-1\",\n  \"address\": \"Calle 85 #15-20\",\n  \"city\": \"Bogotá\",\n  \"country\": \"Colombia\",\n  \"openAt\": \"07:00\",\n  \"closeAt\": \"22:00\",\n  \"tableCount\": 4\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses",
							"host": ["{{baseUrl}}"],
							"path": ["businesses"]
						}
					}
				},
				{
					"name": "List My Businesses",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses",
							"host": ["{{baseUrl}}"],
							"path": ["businesses"]
						}
					}
				},
				{
					"name": "Get Business",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}"]
						}
					}
				},
				{
					"name": "Update Business",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Café Mezo Updated\",\n  \"nit\": \"900123456-2\",\n  \"openAt\": \"06:00\",\n  \"closeAt\": \"23:00\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}"]
						}
					}
				},
				{
					"name": "Toggle Business Status",
					"request": {
						"method": "PATCH",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "status"]
						}
					}
				},
				{
					"name": "Delete Business",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}"]
						}
					}
				}
			]
		},
		{
			"name": "03. Categories",
			"item": [
				{
					"name": "Create Category",
