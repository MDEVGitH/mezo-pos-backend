					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/products/{{productId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "products", "{{productId}}"]
						}
					}
				}
			]
		},
		{
			"name": "05. Tables",
			"item": [
				{
					"name": "Create Table (auto number)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('tableId', json.id);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/tables",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "tables"]
						}
					}
				},
				{
					"name": "List Tables",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/tables",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "tables"]
						}
					}
				},
				{
					"name": "Get Table Summary",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/tables/{{tableId}}/summary",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "tables", "{{tableId}}", "summary"]
						}
					}
				},
				{
