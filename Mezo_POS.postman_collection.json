						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/categories",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "categories"]
						}
					}
				},
				{
					"name": "Update Category",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Bebidas frías\",\n  \"icon\": \"🧊\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/businesses/{{businessId}}/categories/{{categoryId}}",
							"host": ["{{baseUrl}}"],
							"path": ["businesses", "{{businessId}}", "categories", "{{categoryId}}"]
						}
